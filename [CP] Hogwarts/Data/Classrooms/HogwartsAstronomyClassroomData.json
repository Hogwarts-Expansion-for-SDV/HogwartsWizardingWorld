      "LogName": "Hogwarts Bell Tower Courtyard Astronomy Table",
      "Action": "EditMap",
      "Target": "Maps/{{ModId}}_HogwartsBellTowerCourtyard",
      "MapTiles": [
        {
          "Position": {
            "X": 59,
            "Y": 25
          },
          "Layer": "Buildings",
          "SetProperties": {
            "DMT/changeProperties_Item((O){{ModId}}_HogwartsStellascope)": "Action=MEEP_CloseupInteraction_Image {{ModId}}/TransparentStellascopeAfterNext 0 0 128 128",
            "DMT/addTilesheet_Load": "{{ModId}}_Stellascope,Maps/z_HogsmeadeInterior_Hxoni_Hogwarts",
            "DMT/changeMultipleIndex_Item((O){{ModId}}_HogwartsStellascope)": "Front1 59 24={{ModId}}_Stellascope/834"
          }
        },
        {
          "Position": {
            "X": 59,
            "Y": 26
          },
          "Layer": "Buildings",
          "SetProperties": {
            "DMT/take_Once_Item((O){{AstronomyStellaObject}})": "(O){{AstronomyStellaObject}}",
            "DMT/give_Once_Item((O){{AstronomyStellaObject}})": "(O){{ModId}}_{{Random:{{Card}}}}",
            "DMT/mail_Once_Item((O){{AstronomyStellaObject}})": "{{ModId}}_AstronomyTableStellaBellTowerCourtyard"
          }
        }
      ],
      "When": {
        "HasMod |contains= aedenthorn.DynamicMapTilesExtended": true,
        "HasMod |contains= DecidedlyHuman.MappingExtensionsAndExtraProperties": true
      }
    },
