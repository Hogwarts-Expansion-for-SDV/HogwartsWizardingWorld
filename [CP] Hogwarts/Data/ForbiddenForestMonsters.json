          "Condition": "PLAYER_HAS_MAIL Any {{ModId}}_ForbiddenForestMonsterSpawn received, {{HasMod |contains=aedenthorn.CustomMonsters}}, {{HasMod |contains=aedenthorn.DynamicMapTilesExtended}}",
