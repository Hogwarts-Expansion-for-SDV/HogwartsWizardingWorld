          "ContextTags": [
            "{{ModId}}_Hogwarts"
          ],
          "ExcludeFromShippingCollection": true
        }
      }
    },
    {
      "LogName": "Hogwarts Task Hufflepuff",
      "Action": "EditMap",
      "Target": "Maps/SeedShop",
      "MapTiles": [
        {
          "Position": {
            "X": 18,
            "Y": 28
          },
          "Layer": "Buildings",
          "SetProperties": {
            "DMT/animation_Enter": "{{ModId}}.StardewValleyHouseTasks,NotificationSeedShop",
            "DMT/take_Once_Item((O){{ModId}}_HogwartsEmblem)": "(O){{ModId}}_HogwartsEmblem,1",
            "DMT/mail_Once_Item((O){{ModId}}_HogwartsEmblem)": "{{ModId}}_Hufflepuff",
            "DMT/mailbox_Once_Item((O){{ModId}}_HogwartsEmblem)": "{{ModId}}_Wizard",
            "DMT/animationOff_Once_Item((O){{ModId}}_HogwartsEmblem)": "{{ModId}}.StardewValleyHouseTasks,NotificationSeedShop",
            "DMT/message_Once_Item((O){{ModId}}_HogwartsEmblem)": "You toss the emblem at the designated location.",
            "DMT/animation_Once_Item((O){{ModId}}_HogwartsEmblem)": "{{ModId}}.StardewValleyHouseTasks,HouseTaskOwlSeedShop"
          }
        }
      ],
      "When": {
        "HasMod |contains= aedenthorn.DynamicMapTilesExtended": true,
        "HasFlag |contains= {{ModId}}_HogwartsLetterAcceptance": true,
        "HasFlag |contains= {{ModId}}_Hufflepuff, {{ModId}}_Gryffindor, {{ModId}}_Slytherin, {{ModId}}_Ravenclaw": false
      }
    },
